# YouTube Data API v3 Key
# Get your API key: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_YOUTUBE_API_KEY=your_youtube_api_key_here

# Site URL (used for OG images, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to "false" to use real YouTube API (requires API key)
# Defaults to "true" — app works without an API key
NEXT_PUBLIC_USE_MOCK_DATA=true
